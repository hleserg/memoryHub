# docker/.env.example — memoryHub environment variables template
# Copy to docker/.env and fill in real values
# ⚠️  NEVER commit docker/.env to version control (it's in .gitignore)
# See ARCHITECTURE.md §10 Единый конфиг for full config reference

# ─────────────────────────────────────────────────────────────────────────
# SYSTEM
# ─────────────────────────────────────────────────────────────────────────
MEMORYHUB_ENV=development
# Values: development | staging | production

# ─────────────────────────────────────────────────────────────────────────
# PORTS (override docker-compose.yml defaults)
# ─────────────────────────────────────────────────────────────────────────
API_PORT=3000
MCP_PORT=3100
DASH_PORT=3200
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────
# API HUB
# See ARCHITECTURE.md §4.1 API Key Vault
# First admin key — generated during 'make setup' / 'memoryhub init'
# ─────────────────────────────────────────────────────────────────────────
MEMORYHUB_ADMIN_API_KEY=mhub_dev_admin_REPLACE_WITH_REAL_KEY

# ─────────────────────────────────────────────────────────────────────────
# STORAGE
# See ARCHITECTURE.md §10 storage section
# ─────────────────────────────────────────────────────────────────────────
MEMORYHUB_DATA_DIR=/data/memoryhub
# SQLite path is derived from data dir: ${MEMORYHUB_DATA_DIR}/memoryhub.sqlite

# ─────────────────────────────────────────────────────────────────────────
# EMBEDDINGS PROVIDER
# See ARCHITECTURE.md §10 storage.embeddings
# ─────────────────────────────────────────────────────────────────────────
# For local (no external API needed, default):
MEMORYHUB_EMBEDDINGS_PROVIDER=local

# For OpenAI embeddings (higher quality, costs money):
# MEMORYHUB_EMBEDDINGS_PROVIDER=openai
# MEMORYHUB_EMBEDDINGS_API_KEY=sk-REPLACE_WITH_REAL_KEY

# ─────────────────────────────────────────────────────────────────────────
# REDIS (rate limiting + caching)
# See ARCHITECTURE.md §4.1 Rate Limiter
# ─────────────────────────────────────────────────────────────────────────
MEMORYHUB_REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────────────────
# DISASTER RECOVERY — Cloud Storage
# See ARCHITECTURE.md §4.9 Disaster Recovery, §10 disaster_recovery section
# ─────────────────────────────────────────────────────────────────────────
MEMORYHUB_DR_PROVIDER=backblaze_b2
# Values: backblaze_b2 | aws_s3 | gcs | none

MEMORYHUB_DR_BUCKET=memoryhub-dr
MEMORYHUB_DR_REGION=eu-central-003
MEMORYHUB_DR_ACCESS_KEY=REPLACE_WITH_REAL_KEY
MEMORYHUB_DR_SECRET_KEY=REPLACE_WITH_REAL_SECRET

# Encryption key for DR backups (AES-256-GCM)
# Generate with: openssl rand -hex 32
MEMORYHUB_DR_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS

# ─────────────────────────────────────────────────────────────────────────
# GITHUB SNAPSHOTS
# See ARCHITECTURE.md §4.10 GitHub Snapshots
# Token needs: repo scope (push to private repo)
# ─────────────────────────────────────────────────────────────────────────
MEMORYHUB_GITHUB_TOKEN=ghp_REPLACE_WITH_REAL_TOKEN
MEMORYHUB_GITHUB_REPO_OWNER=your-github-username
MEMORYHUB_GITHUB_REPO_NAME=memoryhub-snapshots

# ─────────────────────────────────────────────────────────────────────────
# TELEGRAM ALERTS
# See ARCHITECTURE.md §4.8 Alert Router, §10 integrations.telegram
# ─────────────────────────────────────────────────────────────────────────
MEMORYHUB_TELEGRAM_TOKEN=REPLACE_WITH_BOT_TOKEN
MEMORYHUB_ALERT_CHAT_ID=REPLACE_WITH_CHAT_ID
# Get chat ID: send a message to your bot then call:
# https://api.telegram.org/bot<TOKEN>/getUpdates

# ─────────────────────────────────────────────────────────────────────────
# SKILLS SYSTEM
# See ARCHITECTURE.md §4.6 Skills System
# ─────────────────────────────────────────────────────────────────────────
MEMORYHUB_SKILLS_API_KEY=mhub_dev_skills_REPLACE_WITH_REAL_KEY

# ─────────────────────────────────────────────────────────────────────────
# INTEGRITY SIGNING
# See ARCHITECTURE.md §4.4 Integrity Checksums
# System-wide HMAC key for memory record signatures
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────
MEMORYHUB_SIGNING_KEY=REPLACE_WITH_64_HEX_CHARS

# ─────────────────────────────────────────────────────────────────────────
# letheClaw integration (legacy migration mode)
# See ARCHITECTURE.md §10 integrations.letheclaw
# ─────────────────────────────────────────────────────────────────────────
MEMORYHUB_LETHECLAW_ENABLED=false
MEMORYHUB_LETHECLAW_URL=http://192.168.1.51:51234
