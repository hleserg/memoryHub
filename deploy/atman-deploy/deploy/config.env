# =============================================================================
# Atman — конфигурация деплоя
# Этот файл — в git. Секреты (пароли, ключи) — НЕ здесь.
# Секреты генерируются автоматически в ~/.atman/.secrets
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_VERSION=16
POSTGRES_USER=atman
POSTGRES_DB=atman
POSTGRES_PORT=5432

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_VERSION=latest
QDRANT_PORT=6333

# ── Модели Ollama ─────────────────────────────────────────────────────────────
# LLM для рефлексии
OLLAMA_LLM_MODEL=qwen3.5:9b

# Embedding модель (2560 dims, мультиязычная)
OLLAMA_EMBED_MODEL=qwen3-embedding:4b

# Сколько держать модель в памяти после последнего запроса
OLLAMA_KEEP_ALIVE=5m

# Flash Attention — улучшает работу с длинным контекстом (1=включено)
OLLAMA_FLASH_ATTENTION=1

# Максимум параллельных запросов к модели
OLLAMA_NUM_PARALLEL=1

# Максимум одновременно загруженных моделей
OLLAMA_MAX_LOADED_MODELS=2

# ── Qdrant коллекции ─────────────────────────────────────────────────────────
# Размерность векторов (должна совпадать с embedding моделью)
VECTOR_DIM=2560

# Коллекции
QDRANT_COLLECTION_FACTS=atman_facts
QDRANT_COLLECTION_EXPERIENCES=atman_experiences
